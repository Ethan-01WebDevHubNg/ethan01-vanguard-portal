rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Verification Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // --- 1. ADMINS COLLECTION ---
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == adminId;
      allow create, delete: if false; 
    }

    // --- 2. CLIENTS COLLECTION ---
    match /clients/{clientId} {
      // Admins read all. Clients can only read their specific profile.
      allow read: if isAuthenticated() && (
        isAdmin() || 
        resource.data.authUid == request.auth.uid
      );
      // Only admins can modify client profiles
      allow write: if isAdmin();
    }

    // --- 3. PROJECTS COLLECTION ---
    match /projects/{projectId} {
      // Admins read all. Clients read ONLY IF the project's linked clientId has their authUid.
      allow read: if isAuthenticated() && (
        isAdmin() || 
        get(/databases/$(database)/documents/clients/$(resource.data.clientId)).data.authUid == request.auth.uid
      );
      
      allow create: if isAdmin();
      
      // Standard admins need to be in assignedTeam. (Super Admins bypass logic will be handled via Cloud Functions if needed)
      allow update, delete: if isAdmin() && (request.auth.uid in resource.data.assignedTeam);
      
      // --- CASCADE TO SUBCOLLECTIONS (Tasks, Deliverables, Invoices) ---
      match /{subDoc=**} {
        // Subcollections inherit the same read permissions as the parent project
        allow read: if isAuthenticated() && (
          isAdmin() || 
          get(/databases/$(database)/documents/clients/$(get(/databases/$(database)/documents/projects/$(projectId)).data.clientId)).data.authUid == request.auth.uid
        );
        // Only admins can push files, tasks, and invoices
        allow write: if isAdmin() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.assignedTeam);
      }
    }

    // --- 4. DRAFTS & METADATA ---
    match /drafts/{draftId} {
      allow read, write: if isAdmin() && resource.data.adminId == request.auth.uid;
      allow create: if isAdmin();
    }

    match /metadata/{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}